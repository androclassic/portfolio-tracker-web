{
  "name": "portfolio-tracker-web",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev --name init",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "warm-cache": "tsx prisma/warm-price-cache.ts"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^6.13.0",
    "axios": "^1.11.0",
    "bcryptjs": "^2.4.3",
    "csv-parse": "^6.1.0",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "jsonwebtoken": "^9.0.2",
    "next": "^15.5.12",
    "next-auth": "^4.24.10",
    "nodemailer": "^7.0.13",
    "prisma": "^6.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "swr": "^2.3.6",
    "zod": "^4.0.17"
  },
  "overrides": {
    "next-auth": {
      "nodemailer": "$nodemailer"
    }
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/bcryptjs": "^2.4.6",
    "@types/csv-parse": "^1.1.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.10",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "tsx": "^4.20.3",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
